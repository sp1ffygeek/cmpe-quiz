    "module": "M1 — Similarity & Evaluation",
    "formulas": [
      {
        "name": "Cosine Similarity",
        "latex": "$$\\cos(\\mathbf{x},\\mathbf{y}) = \\frac{\\mathbf{x} \\cdot \\mathbf{y}}{\\lVert\\mathbf{x}\\rVert \\lVert\\mathbf{y}\\rVert}$$"
      },
      {
        "name": "Jaccard Similarity",
        "latex": "$$J(A,B) = \\frac{\\lvert A \\cap B \\rvert}{\\lvert A \\cup B \\rvert}$$"
      },
      {
        "name": "Pearson Correlation",
        "latex": "$$r = \\frac{\\sum(x_i - \\bar{x})(y_i - \\bar{y})}{\\sqrt{\\sum(x_i-\\bar{x})^2 \\sum(y_i-\\bar{y})^2}}$$"
      },
      {
        "name": "Precision",
        "latex": "$$P = \\frac{TP}{TP+FP}$$"
      },
      {
        "name": "Recall",
        "latex": "$$R = \\frac{TP}{TP+FN}$$"
      },
      {
        "name": "F1 Score",
        "latex": "$$F_1 = \\frac{2PR}{P+R}$$"
      },
      {
        "name": "RMSE",
        "latex": "$$RMSE = \\sqrt{\\frac{1}{n}\\sum(y_i - \\hat{y}_i)^2}$$"
      },
      {
        "name": "Precision@k",
        "latex": "$$P@k = \\frac{\\lvert \\text{relevant} \\cap \\text{top-k} \\rvert}{k}$$"
      },
      {
        "name": "Recall@k",
        "latex": "$$R@k = \\frac{\\lvert \\text{relevant} \\cap \\text{top-k} \\rvert}{\\lvert \\text{relevant} \\rvert}$$"
      },
      {
        "name": "NDCG / DCG",
        "latex": "$$DCG@k = \\sum_{i=1}^k \\frac{rel_i}{\\log_2(i+1)}$$"
      }
    ]
  },
  {
