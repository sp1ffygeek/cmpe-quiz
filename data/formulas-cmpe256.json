        "name": "UCB (Upper Confidence Bound)",
        "latex": "$$a_t = \\arg\\max_a \\left[\\hat{\\mu}_a + c\\sqrt{\\frac{\\ln t}{N_a}}\\right]$$"
      }
    ]
