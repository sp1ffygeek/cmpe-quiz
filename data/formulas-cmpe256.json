    "formulas": [
      {
        "name": "User-Based CF (Weighted)",
        "latex": "$$\\hat{r}_{uj} = \\frac{\\sum_{v} sim(u,v) \\cdot r_{vj}}{\\sum_{v} \\lvert sim(u,v) \\rvert}$$"
      },
